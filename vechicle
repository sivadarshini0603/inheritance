class vechicle:
    def getdetails(self):
        self.make=input("enter your make")
        self.year=input("enter your year")
        self.color=input("enter your color")
    def display_info(self):
        print("make:",self.make)
        print("year:",self.year)
        print("color:",self.color)
class car(vechicle):
    def getcardetails(self):
        super().getdetails()
        self.model=input("enter your model")
        self.capacity=input("enter your capacity")
    def display_car(self):
        super().display_info()
        print("model:",self.model)
        print("capacity:",self.capacity)
class bike(vechicle):
    def getbikedetails(self):
        super().getdetails()
        self.type=input("enter your type")
        self.mileage=input("enter your mileage")
    def display_bike(self):
        super().display_info()
        print("type:",self.type)
        print("mileage:",self.mileage)
c=car()
c.getcardetails()
print("******CAR DETAILS******")
c.display_car()
b=bike()
b.getbikedetails()
print("******BIKE DETAILS******")
b.display_bike()
